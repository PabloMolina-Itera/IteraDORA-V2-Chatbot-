<header class="w-full bg-white dark:bg-[#002635] 
               border-b border-gray-200 dark:border-[#004e66] 
               transition-colors duration-300">

  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- LOGO -->
    <a href="/">
      <img 
        src="/logo-iteradora.png" 
        alt="IteraDORA"
        class="h-10 object-contain dark:brightness-0 dark:invert"
      />
    </a>

    <!-- MENU -->
    <nav class="hidden md:flex items-center gap-8 
                text-[#00334E] dark:text-gray-200 font-medium">

      <a href="/#inicio" 
         class="hover:text-[#00607B] dark:hover:text-[#00A8D8] transition">
        Inicio
      </a>

      <a href="/#beneficios" 
         class="hover:text-[#00607B] dark:hover:text-[#00A8D8] transition">
        Beneficios
      </a>

      <a href="/#diagnostico" 
         class="hover:text-[#00607B] dark:hover:text-[#00A8D8] transition">
        Diagnóstico
      </a>

    </nav>

    <div class="flex items-center gap-4">

      <!-- BOTÓN DARK MODE -->
      <button 
        id="themeToggle"
        aria-label="Cambiar tema"
        class="p-2 rounded-lg bg-gray-200 dark:bg-gray-800 transition text-xl"
      >
        🌙
      </button>

      <!-- CTA -->
      <a 
        href="/#diagnostico"
        class="bg-[#00A8D8] hover:bg-[#00607B] 
               text-white px-5 py-2.5 rounded-lg 
               font-semibold shadow transition"
      >
        Solicitar diagnóstico
      </a>

    </div>

  </div>
</header>

