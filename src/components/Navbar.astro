---
// Spacer compensa la altura del navbar fixed para que el contenido no salte
---

<div id="navbarSpacer" class="h-[68px]"></div>

<header
  id="navbarHeader"
  class="fixed top-0 left-0 w-full z-50
         bg-white/80 dark:bg-[#002635]/80
         border-b border-transparent
         transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">

    <!-- LOGO -->
    <a href="/" class="shrink-0">
      <img
        src="/logo-iteradora.png"
        alt="IteraDORA"
        class="h-9 md:h-10 object-contain dark:brightness-0 dark:invert"
      />
    </a>

    <!-- ACCIONES DERECHA -->
    <div class="flex items-center gap-4">

      <!-- TOGGLE DARK/LIGHT CON SVG -->
      <button
        id="themeToggle"
        aria-label="Cambiar modo claro/oscuro"
        title="Cambiar modo claro/oscuro"
        class="relative w-14 h-7 rounded-full bg-gray-300 dark:bg-gray-600
               transition-colors duration-300
               focus:outline-none focus:ring-2 focus:ring-[#00A8D8]/50"
      >
        <span id="themeKnob"
              class="absolute top-0.5 left-0.5 w-6 h-6 rounded-full
                     bg-white dark:bg-[#00334E] shadow-md
                     flex items-center justify-center
                     transition-transform duration-300
                     dark:translate-x-7"
        >
          <!-- Ícono sol (modo claro) -->
          <svg id="iconSun" class="w-3.5 h-3.5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
          <!-- Ícono luna (modo oscuro) -->
          <svg id="iconMoon" class="w-3.5 h-3.5 text-yellow-300 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
          </svg>
        </span>
      </button>

      <!-- BOTÓN HAMBURGUESA (TODOS LOS TAMAÑOS) -->
      <button
        id="hamburgerBtn"
        aria-label="Abrir menú"
        title="Abrir menú"
        class="relative w-9 h-9 flex flex-col items-center justify-center gap-1.5
               focus:outline-none focus:ring-2 focus:ring-[#00A8D8]/50 rounded-lg"
      >
        <span class="hamburger-line w-5 h-0.5 bg-[#00334E] dark:bg-white rounded-full transition-all duration-300 origin-center"></span>
        <span class="hamburger-line w-5 h-0.5 bg-[#00334E] dark:bg-white rounded-full transition-all duration-300 origin-center"></span>
        <span class="hamburger-line w-5 h-0.5 bg-[#00334E] dark:bg-white rounded-full transition-all duration-300 origin-center"></span>
      </button>

    </div>
  </div>

  <!-- MENÚ DESPLEGABLE (TODOS LOS TAMAÑOS) -->
  <div
    id="mobileMenu"
    class="overflow-hidden transition-all duration-300 ease-in-out"
    style="max-height: 0; opacity: 0;"
  >
    <nav class="px-6 pb-5 pt-2 flex flex-col gap-3
                text-[#00334E] dark:text-gray-200 font-medium
                max-w-7xl mx-auto">
      <a href="/#inicio"
         class="mobile-nav-link py-2 px-3 rounded-lg
                hover:bg-[#00A8D8]/10 dark:hover:bg-[#00A8D8]/20
                transition-colors">
        Inicio
      </a>
      <a href="/#beneficios"
         class="mobile-nav-link py-2 px-3 rounded-lg
                hover:bg-[#00A8D8]/10 dark:hover:bg-[#00A8D8]/20
                transition-colors">
        Beneficios
      </a>
      <a href="/#diagnostico"
         class="mobile-nav-link py-2 px-3 rounded-lg
                hover:bg-[#00A8D8]/10 dark:hover:bg-[#00A8D8]/20
                transition-colors">
        Diagnóstico
      </a>
      <a href="/#diagnostico"
         class="mobile-nav-link mt-2 inline-block text-center
                bg-[#00A8D8] hover:bg-[#00607B]
                text-white px-5 py-2.5 rounded-lg
                font-semibold shadow transition-colors">
        Solicitar diagnóstico
      </a>
    </nav>
  </div>

</header>

<script>
  // ─── REFERENCIAS ────────────────────────────
  const header = document.getElementById('navbarHeader')!;
  const hamburger = document.getElementById('hamburgerBtn')!;
  const mobileMenu = document.getElementById('mobileMenu')!;
  const lines = document.querySelectorAll<HTMLElement>('.hamburger-line');
  const themeToggle = document.getElementById('themeToggle')!;
  const iconSun = document.getElementById('iconSun')!;
  const iconMoon = document.getElementById('iconMoon')!;

  let menuOpen = false;

  // ─── STICKY + BACKDROP BLUR ─────────────────
  function updateNavbarStyle() {
    const scrolled = window.scrollY > 10;
    if (scrolled) {
      header.classList.add('backdrop-blur-lg', 'shadow-md');
      header.classList.add('border-gray-200', 'dark:border-[#004e66]');
      header.classList.remove('border-transparent');
    } else {
      header.classList.remove('backdrop-blur-lg', 'shadow-md');
      header.classList.remove('border-gray-200', 'dark:border-[#004e66]');
      header.classList.add('border-transparent');
    }
  }

  window.addEventListener('scroll', updateNavbarStyle, { passive: true });
  updateNavbarStyle(); // inicial

  // ─── MENÚ DESPLEGABLE ────────────────────────
  function openMenu() {
    menuOpen = true;
    // Activar stagger en links
    mobileMenu.classList.add('menu-open');
    mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
    mobileMenu.style.opacity = '1';
    // Vortex: líneas colapsan al centro y giran → ✕
    lines[0].style.transform = 'translateY(5px) rotate(45deg)';
    lines[1].style.transform = 'scaleX(0) rotate(90deg)';
    lines[2].style.transform = 'translateY(-5px) rotate(-45deg)';
    hamburger.setAttribute('aria-label', 'Cerrar menú');
    hamburger.setAttribute('title', 'Cerrar menú');
  }

  function closeMenu() {
    menuOpen = false;
    // Desactivar stagger
    mobileMenu.classList.remove('menu-open');
    mobileMenu.style.maxHeight = '0';
    mobileMenu.style.opacity = '0';
    // Restaurar hamburguesa
    lines[0].style.transform = '';
    lines[1].style.transform = '';
    lines[2].style.transform = '';
    hamburger.setAttribute('aria-label', 'Abrir menú');
    hamburger.setAttribute('title', 'Abrir menú');
  }

  hamburger.addEventListener('click', () => {
    if (menuOpen) closeMenu();
    else openMenu();
  });

  // Cerrar al hacer clic en un link del menú móvil
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuOpen) closeMenu();
  });

  // Ajustar altura en resize (por si cambia el contenido)
  window.addEventListener('resize', () => {
    if (menuOpen) {
      mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
    }
  });

  // ─── TOGGLE TEMA (SVG SOL/LUNA) ────────────
  function updateThemeUI() {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      iconSun.classList.add('hidden');
      iconMoon.classList.remove('hidden');
    } else {
      iconSun.classList.remove('hidden');
      iconMoon.classList.add('hidden');
    }
  }

  // Sincronizar UI inicial
  updateThemeUI();

  themeToggle.addEventListener('click', () => {
    const isDark = !document.documentElement.classList.contains('dark');
    document.documentElement.classList.toggle('dark', isDark);
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateThemeUI();
  });
</script>

<style is:global>
  .hamburger-line {
    display: block;
    /* Vortex: transición independiente para cada propiedad */
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.2s ease;
  }

  /* ─── STAGGER: links aparecen uno tras otro ─── */
  .mobile-nav-link {
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.35s ease, transform 0.35s ease;
    transition-delay: 0s;
  }

  /* Cuando el menú está abierto, los links cobran vida en cascada */
  .menu-open .mobile-nav-link {
    opacity: 1;
    transform: translateY(0);
  }

  .menu-open .mobile-nav-link:nth-child(1) { transition-delay: 0.05s; }
  .menu-open .mobile-nav-link:nth-child(2) { transition-delay: 0.12s; }
  .menu-open .mobile-nav-link:nth-child(3) { transition-delay: 0.19s; }
  .menu-open .mobile-nav-link:nth-child(4) { transition-delay: 0.26s; }
</style>
