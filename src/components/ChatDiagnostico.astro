---
import '../styles/chat-diagnostico.css';
---

<section class="w-full pt-4 pb-6 bg-gradient-to-b from-[#F7FAFC] to-[#E8EDF2] dark:from-[#001C26] dark:to-[#002633]" style="min-height: calc(100vh - 68px)">
  <div class="max-w-2xl mx-auto px-4">

    <div class="mb-3 text-center">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-[#00A8D8]/10 mb-3">
        <span class="text-2xl">📊</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-extrabold text-[#00334E] dark:text-white mb-1">
        Diagnóstico DevOps
      </h1>
      <p class="text-gray-500 dark:text-gray-400 text-xs max-w-md mx-auto">
        Evaluación integral de madurez en prácticas DevOps basada en la metodología DORA.
      </p>
    </div>

    <div
      id="chat-container"
      class="flex flex-col bg-white dark:bg-[#0A3E52] rounded-3xl shadow-xl shadow-gray-200/50 dark:shadow-black/30 overflow-hidden border border-gray-100 dark:border-gray-700/50"
      style="height: 520px; max-height: calc(100vh - 280px);"
    >
      <div class="bg-gradient-to-r from-[#00334E] to-[#004466] dark:from-[#002633] dark:to-[#00334E] px-5 py-4 flex items-center gap-3">
        <div class="relative">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-[#00A8D8] to-[#0095c2] flex items-center justify-center text-white font-bold text-sm shadow-lg shadow-[#00A8D8]/30">IA</div>
          <span class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-emerald-400 rounded-full border-2 border-[#00334E]"></span>
        </div>
        <div>
          <p class="text-white font-semibold text-sm">Asistente IteraDORA</p>
          <p class="text-gray-300 text-xs flex items-center gap-1">
            <span class="inline-block w-1.5 h-1.5 bg-emerald-400 rounded-full"></span>
            Basado en metodología DORA
          </p>
        </div>
      </div>

      <div
        id="chat-messages"
        class="flex-1 p-5 space-y-4 overflow-y-auto bg-gradient-to-b from-gray-50/50 to-white dark:from-[#0A3E52]/50 dark:to-[#0A3E52]"
        style="scroll-behavior: smooth;"
      >
        <div class="flex items-end gap-2 justify-start">
          <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-[#00A8D8] to-[#0095c2] flex items-center justify-center text-white text-[10px] font-bold flex-shrink-0 mb-1 shadow-md">IA</div>
          <div class="max-w-[80%] px-4 py-2.5 rounded-2xl rounded-bl-md bg-white dark:bg-[#002633] text-[#00334E] dark:text-gray-100 border border-gray-100 dark:border-gray-700/50 text-sm leading-relaxed shadow-sm">
            ¡Hola! 👋 Soy IteraDORA. Te ayudaré a evaluar el nivel de madurez DevOps de tu organización utilizando la metodología DORA.<br><br>
            El diagnóstico es rápido: solo responderás 11 preguntas de Sí o No. Al finalizar, recibirás una clasificación y algunas recomendaciones para identificar oportunidades de mejora.
          </div>
        </div>
      </div>

      <!-- Botón Comencemos (inicial) -->
      <div id="comenzar-container" class="border-t border-gray-100 dark:border-gray-700/50 px-4 py-3 bg-white dark:bg-[#0A3E52]">
        <button id="btn-comenzar" class="w-full bg-gradient-to-r from-[#00A8D8] to-[#0095c2] hover:from-[#0095c2] hover:to-[#0088b0] text-white py-3 rounded-2xl font-semibold text-sm transition-all duration-200 shadow-md shadow-[#00A8D8]/20 active:scale-95">Comencemos</button>
      </div>
      <!-- Botones Sí / No -->
      <div id="btn-container" class="hidden border-t border-gray-100 dark:border-gray-700/50 px-4 py-3 bg-white dark:bg-[#0A3E52]">
        <div class="flex gap-3">
          <button id="btn-si" class="flex-1 py-3 rounded-2xl font-semibold text-sm transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed shadow-sm active:scale-95 bg-emerald-500 hover:bg-emerald-600 text-white shadow-emerald-500/20">✓  Sí</button>
          <button id="btn-no" class="flex-1 py-3 rounded-2xl font-semibold text-sm transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed shadow-sm active:scale-95 bg-red-500 hover:bg-red-600 text-white shadow-red-500/20">✗  No</button>
        </div>
      </div>

      <!-- Botón Recomendaciones (aparece después del resultado) -->
      <div id="rec-container" class="hidden border-t border-gray-100 dark:border-gray-700/50 px-4 py-3 bg-white dark:bg-[#0A3E52]">
        <button id="btn-rec" class="w-full py-3 rounded-2xl font-semibold text-sm transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed shadow-sm active:scale-95 bg-gradient-to-r from-[#00A8D8] to-[#0095c2] hover:from-[#0095c2] hover:to-[#0088b0] text-white shadow-[#00A8D8]/20">💡  Solicitar recomendaciones</button>
      </div>
      <!-- Botón Diagnóstico Profundo (aparece después del resultado) -->
      <div id="deep-container" class="hidden border-t border-gray-100 dark:border-gray-700/50 px-4 py-3 bg-white dark:bg-[#0A3E52]">
        <button id="btn-deep" class="w-full py-3 rounded-2xl font-semibold text-sm transition-all duration-200 disabled:opacity-30 disabled:cursor-not-allowed shadow-sm active:scale-95 bg-gradient-to-r from-[#5495CC] to-[#3E7CB5] hover:from-[#3E7CB5] hover:to-[#2A639C] text-white shadow-[#5495CC]/20">🔍  Diagnóstico Profundo</button>
      </div>
    </div>

    <div id="result-card" class="hidden bg-white dark:bg-[#0A3E52] rounded-3xl shadow-2xl shadow-gray-300/50 dark:shadow-black/40 border border-gray-100 dark:border-gray-700/50 overflow-hidden mt-6 max-w-sm mx-auto">
      <div class="bg-gradient-to-r from-[#00334E] to-[#004466] px-5 py-3.5 flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-emerald-400/20 flex items-center justify-center text-emerald-300 font-bold text-sm">✓</div>
        <p class="text-white font-semibold text-sm">Diagnóstico Completado</p>
      </div>
      <div class="p-5 text-center">
        <div id="result-content" class="mb-5 text-[#00334E] dark:text-white text-sm space-y-2"></div>
        <div class="flex gap-2.5 justify-center">
          <button id="btn-volver-chat" class="px-5 py-2.5 bg-gradient-to-r from-[#00A8D8] to-[#0095c2] hover:from-[#0095c2] hover:to-[#0088b0] text-white rounded-xl font-semibold text-xs transition-all duration-200 shadow-lg shadow-[#00A8D8]/20">Regresar al chat</button>
          <button id="btn-salir" class="px-5 py-2.5 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-600 dark:text-gray-300 rounded-xl font-semibold text-xs transition-all duration-200">Volver al inicio</button>
        </div>
      </div>
    </div>

    <!-- Deep Result Card -->
    <div id="deep-result-card" class="hidden bg-white dark:bg-[#0A3E52] rounded-3xl shadow-2xl shadow-gray-300/50 dark:shadow-black/40 border border-gray-100 dark:border-gray-700/50 overflow-hidden mt-6 max-w-2xl w-full mx-auto">
      <div class="bg-gradient-to-r from-[#3E7CB5] to-[#2A639C] px-5 py-3.5 flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-[#5495CC]/20 flex items-center justify-center text-[#8ABCDB] font-bold text-sm">◆</div>
        <p class="text-white font-semibold text-sm">Diagnóstico Profundo Completado</p>
      </div>
      <div class="p-5 text-center">
        <div id="deep-result-content" class="mb-5 text-[#00334E] dark:text-white text-sm space-y-2"></div>
        <div class="flex gap-2.5 justify-center">
          <button id="btn-salir-deep" class="px-5 py-2.5 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 text-gray-600 dark:text-gray-300 rounded-xl font-semibold text-xs transition-all duration-200">Volver al inicio</button>
        </div>
      </div>
    </div>

    <p id="chat-disclaimer" class="text-xs text-gray-400 dark:text-gray-500 text-center mt-4">
      Responde con honestidad para obtener un diagnóstico preciso.
    </p>

  </div>
</section>

<script src="../scripts/chat-diagnostico.ts"></script>
