---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="IteraDORA - Diagnóstico DevOps basado en DORA">

  <!-- HERO -->
<section 
  id="inicio"
  class="relative min-h-[90vh] flex items-center bg-cover bg-center bg-no-repeat"
  style="background-image: url('/fondo_hero.jpg');"
>

  <!-- Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b md:bg-gradient-to-r from-[#00334E]/95 via-[#00334E]/85 to-transparent"></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-16 sm:py-20">

    <div class="max-w-2xl">

      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight tracking-tight text-white mb-6">
        Descubre el nivel real de madurez DevOps de tu organización
      </h1>

      <p class="text-base sm:text-lg md:text-xl text-gray-200 mb-8 sm:mb-10 leading-relaxed">
        Diagnóstico automatizado basado en la metodología DORA.
        Toma decisiones estratégicas respaldadas por datos.
      </p>

      <a href="#diagnostico"
         class="inline-block w-full sm:w-auto text-center
                bg-[#00A8D8] hover:bg-[#0095c2]
                px-6 sm:px-8 py-4
                rounded-xl text-base sm:text-lg font-semibold
                shadow-xl transition duration-300 ease-in-out
                transform hover:scale-105 active:scale-95">
        Solicitar diagnóstico
      </a>

    </div>

  </div>

</section>

<!-- BENEFICIOS PREMIUM -->
<section id="beneficios"
         class="py-32 bg-[#F4F6F8] dark:bg-[#001C26] transition-colors duration-500">

  <div class="max-w-7xl mx-auto px-6">

    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- IMAGEN -->
      <div class="reveal relative">

        <div class="relative rounded-[40px] overflow-hidden shadow-2xl group">

          <img 
            src="/beneficios_01.jpg"
            alt="Beneficios IteraDORA"
            class="w-full h-[520px] object-cover
                   transition-transform duration-700
                   group-hover:scale-105"
          />

          <!-- Overlay premium -->
          <div class="absolute inset-0 
                      bg-gradient-to-tr 
                      from-[#00334E]/40 
                      via-transparent 
                      to-[#00A8D8]/20">
          </div>

        </div>

      </div>


      <!-- TEXTO -->
      <div class="reveal">

      <h2 class="text-4xl md:text-5xl font-extrabold mb-8 leading-tight">
  <span class="text-black dark:text-white">
    Beneficios
  </span>
  <span class="text-[#4DBFD9]">
    IteraDORA
  </span>
</h2>

        <p class="text-lg text-gray-600 dark:text-gray-300 
                  leading-relaxed mb-8">
          IteraDORA no es solo una evaluación técnica. Es una herramienta estratégica 
          que acelera procesos, posiciona la consultoría y genera valor real en clientes 
          y equipos ejecutivos.
        </p>

        <ul class="space-y-6">

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20 
                        flex items-center justify-center text-[#00A8D8] font-bold">
              1
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Acelera el diagnóstico en prácticas DevOps con claridad inmediata.
            </p>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20 
                        flex items-center justify-center text-[#00A8D8] font-bold">
              2
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Refuerza el posicionamiento como consultores integrales en nube y DevOps.
            </p>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20 
                        flex items-center justify-center text-[#00A8D8] font-bold">
              3
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Genera valor técnico y gerencial para una toma de decisiones estratégica.
            </p>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20 
                        flex items-center justify-center text-[#00A8D8] font-bold">
              4
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Impulsa nuevas oportunidades comerciales en migraciones y consultoría.
            </p>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20 
                        flex items-center justify-center text-[#00A8D8] font-bold">
              5
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Permite recolectar datos clave para decisiones basadas en evidencia.
            </p>
          </li>

        </ul>

      </div>

    </div>

  </div>

</section>
  <!-- CÓMO FUNCIONA -->  
  <section id="como-funciona"
           class="py-28 bg-[#e5e7e8] dark:bg-[#002633] transition-colors duration-500">

    <div class="max-w-6xl mx-auto px-6 text-center">

      <h2 class="text-4xl md:text-5xl font-extrabold 
                 text-[#00334E] dark:text-white mb-16 reveal">
        ¿Cómo funciona?
      </h2>

      <div class="grid md:grid-cols-3 gap-10">

        <!-- CARD 1 -->
        <div class="reveal group flex flex-col justify-between
                    bg-white dark:bg-[#0A3E52]
                    p-10 rounded-2xl shadow-md
                    transition-all duration-500
                    hover:-translate-y-4 hover:shadow-2xl
                    hover:ring-2 hover:ring-[#00A8D8]/50
                    hover:bg-sky-600/50">

          <div>
            <div class="text-5xl mb-6 transition-transform duration-500 group-hover:scale-125">
              1️⃣
            </div>

            <h3 class="text-2xl font-bold mb-4">
              Evaluación
            </h3>

            <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-8">
              Responde una encuesta guiada basada en la metodología DORA.
            </p>
          </div>

        </div>

        <!-- CARD 2 -->
        <div class="reveal group flex flex-col justify-between
                    bg-white dark:bg-[#0A3E52]
                    p-10 rounded-2xl shadow-md
                    transition-all duration-500
                    hover:-translate-y-4 hover:shadow-2xl
                    hover:ring-2 hover:ring-[#00A8D8]/50
                    hover:bg-sky-600/50">

          <div>
            <div class="text-5xl mb-6 transition-transform duration-500 group-hover:scale-125">
              2️⃣
            </div>

            <h3 class="text-2xl font-bold mb-4">
              Análisis
            </h3>

            <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-8">
              Procesamos métricas y calculamos tu nivel real de madurez.
            </p>
          </div>

        </div>

        <!-- CARD 3 -->
        <div class="reveal group flex flex-col justify-between
                    bg-white dark:bg-[#0A3E52]
                    p-10 rounded-2xl shadow-md
                    transition-all duration-500
                    hover:-translate-y-4 hover:shadow-2xl
                    hover:ring-2 hover:ring-[#00A8D8]/50 hover:bg-sky-600/50">

          <div>
            <div class="text-5xl mb-6 transition-transform duration-500 group-hover:scale-125">
              3️⃣
            </div>

            <h3 class="text-2xl font-bold mb-4">
              Recomendaciones
            </h3>

            <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-8">
              Recibe un diagnóstico con próximos pasos accionables.
            </p>
          </div>

        </div>

      </div>

    </div>

  </section>


  <!-- NIVELES DE DIAGNÓSTICO -->
  <section id="diagnostico"
           class="py-28 bg-[#F7FAFC] dark:bg-[#002633] transition-colors duration-500">

    <div class="max-w-6xl mx-auto px-6 text-center">

      <h2 class="text-4xl md:text-5xl font-extrabold 
                 text-[#00334E] dark:text-white mb-16 reveal">
        Elige tu nivel de diagnóstico
      </h2>

      <div class="grid md:grid-cols-3 gap-10 items-stretch">

<!-- FUNDACIONAL -->
<div class="reveal group flex flex-col justify-between
            bg-white dark:bg-[#0A3E52]
            p-10 rounded-2xl shadow-md
            transition-all duration-500
            hover:-translate-y-4 hover:shadow-2xl
            hover:ring-2 hover:ring-[#00A8D8]/50">

  <div>
    <div class="text-5xl mb-6 transition-transform duration-500 group-hover:scale-125">
      🌱
    </div>

    <h3 class="text-2xl font-bold mb-4">
      Fundacional
    </h3>

    <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-8">
      Ideal para organizaciones que están comenzando su adopción DevOps.
    </p>
  </div>

  <!-- BOTÓN -->
  <a href="/diagnostico-fundacional"
     class="glow-btn mt-auto inline-block bg-[#00A8D8] hover:bg-[#0095c2]
            text-white px-8 py-3 rounded-xl
            font-semibold shadow-lg
            transition transform hover:scale-110">
    Iniciar diagnóstico
  </a>

</div>


<!-- INTERMEDIO -->
<div class="reveal group flex flex-col justify-between
            bg-white dark:bg-[#0A3E52]
            p-10 rounded-2xl shadow-md
            transition-all duration-500
            hover:-translate-y-4 hover:shadow-2xl
            hover:ring-2 hover:ring-[#00A8D8]/50">

  <div>
    <div class="text-5xl mb-6 transition-transform duration-500 group-hover:scale-125">
      ⚙️
    </div>

    <h3 class="text-2xl font-bold mb-4">
      Intermedio
    </h3>

    <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-8">
      Para equipos con prácticas DevOps activas que buscan optimización y mejora continua.
    </p>
  </div>

  <!-- BOTÓN -->
  <a href="/diagnostico-intermedio"
     class="glow-btn mt-auto inline-block bg-[#00A8D8] hover:bg-[#0095c2]
            text-white px-8 py-3 rounded-xl
            font-semibold shadow-lg
            transition transform hover:scale-110">
    Evaluar nivel
  </a>

</div>



        <!-- AVANZADO -->
        <div class="reveal group flex flex-col justify-between
                    bg-white dark:bg-[#0A3E52]
                    p-10 rounded-2xl shadow-md
                    transition-all duration-500
                    hover:-translate-y-4 hover:shadow-2xl
                    hover:ring-2 hover:ring-[#00A8D8]/50">

          <div>
            <div class="text-5xl mb-6 transition-transform duration-500 group-hover:scale-125">
              🚀
            </div>

            <h3 class="text-2xl font-bold mb-4">
              Avanzado
            </h3>

            <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-8">
              Diagnóstico profundo para organizaciones con alto nivel de madurez.
            </p>
          </div>

          <a href="/diagnostico-avanzado"
             class="glow-btn mt-auto inline-block bg-[#00A8D8] hover:bg-[#0095c2]
                    text-white px-8 py-3 rounded-xl
                    font-semibold shadow-lg
                    transition transform hover:scale-110">
            Diagnóstico ejecutivo
          </a>

        </div>

      </div>

    </div>

  </section>


 <footer class="bg-white dark:bg-[#001C26] 
               border-t border-gray-200 dark:border-gray-800 
               transition-colors duration-500">

  <div class="max-w-6xl mx-auto px-6 py-14">

    <div class="flex flex-col md:flex-row 
                justify-between items-center gap-8">

      <!-- LOGO -->
      <div class="flex flex-col items-center md:items-start">

        <img 
          src="/logo-iteradora.png"
          alt="IteraDORA"
          class="h-10 object-contain dark:brightness-0 dark:invert"
        />

        <p class="text-sm text-gray-500 dark:text-gray-400 mt-3 text-center md:text-left">
          Diagnóstico DevOps basado en la metodología DORA.
        </p>

      </div>

      <!-- LINKS -->
      <div class="flex gap-8 text-sm font-medium
                  text-gray-600 dark:text-gray-400">

        <a href="#inicio"
           class="hover:text-[#00A8D8] transition">
          Inicio
        </a>

        <a href="#beneficios"
           class="hover:text-[#00A8D8] transition">
          Beneficios
        </a>

        <a href="#diagnostico"
           class="hover:text-[#00A8D8] transition">
          Diagnóstico
        </a>

      </div>

    </div>

    <!-- footer -->
    <div class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-800 text-center">

      <p class="text-sm text-gray-500 dark:text-gray-500">
        © {new Date().getFullYear()} IteraDORA. Todos los derechos reservados.
      </p>

    </div>

  </div>

</footer>