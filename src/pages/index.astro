---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="IteraDORA - Diagnóstico DevOps basado en DORA">

  <!-- HERO -->
<section
  id="inicio"
  class="relative min-h-[90vh] flex items-center justify-center
         overflow-hidden"
>

  <!-- Imagen de fondo con efecto foto viva -->
  <div class="absolute inset-0 living-photo-bg">
    <div class="living-photo-inner absolute inset-0">
      <img
        src="/fondo_hero.jpg"
        alt=""
        class="w-[110%] h-[110%] max-w-none object-cover absolute inset-0"
      />
    </div>
  </div>

  <!-- Overlay oscuro sobre la imagen -->
  <div class="absolute inset-0 bg-[#00334E]/80 dark:bg-[#001219]/85"></div>

  <!-- Orbes de luz -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
                w-[800px] h-[800px] rounded-full
                bg-[#00A8D8]/5 blur-[150px]"></div>
  </div>

  <!-- Contenido centrado -->
  <div class="relative z-10 w-full max-w-4xl mx-auto
              px-6 sm:px-8
              py-20 md:py-28
              text-center">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2
                bg-[#00A8D8]/10 border border-[#00A8D8]/20
                px-4 py-1.5 rounded-full
                text-[#00A8D8] text-sm font-semibold
                tracking-wide uppercase
                mb-6 reveal">
      <span class="w-2 h-2 rounded-full bg-[#00A8D8] animate-pulse"></span>
      Metodología DORA
    </div>

    <!-- Título -->
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl
               font-extrabold leading-[1.08] tracking-tight
               text-white mb-6 reveal">
      Descubre el nivel real de
      <span class="text-[#00A8D8]">madurez DevOps</span>
      de tu organización
    </h1>

    <!-- Descripción -->
    <p class="text-base sm:text-lg md:text-xl text-gray-300
              leading-relaxed mb-10
              max-w-2xl mx-auto reveal">
      Diagnóstico automatizado basado en la metodología DORA.
      Toma decisiones estratégicas respaldadas por datos
      y acelera la transformación de tu equipo.
    </p>

    <!-- CTA + secundario -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12 reveal">
      <a href="#diagnostico"
         class="inline-block text-center
                bg-[#00A8D8] hover:bg-[#0095c2]
                text-white px-8 py-4 rounded-xl
                text-base sm:text-lg font-semibold
                shadow-lg shadow-[#00A8D8]/25
                transition duration-300 ease-in-out
                hover:shadow-xl hover:shadow-[#00A8D8]/30
                hover:-translate-y-0.5 active:scale-95">
        Solicitar diagnóstico
      </a>
      <a href="#beneficios"
         class="text-gray-400 hover:text-white
                text-sm sm:text-base font-medium
                transition-colors flex items-center gap-1.5">
        Ver beneficios
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>

    <!-- Mini stats -->
    <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10 reveal">
      <div>
        <div class="text-2xl sm:text-3xl font-bold text-white">10</div>
        <div class="text-xs sm:text-sm text-gray-400">preguntas clave</div>
      </div>
      <div class="w-px h-8 bg-gray-600 hidden sm:block"></div>
      <div>
        <div class="text-2xl sm:text-3xl font-bold text-white">3</div>
        <div class="text-xs sm:text-sm text-gray-400">niveles DORA</div>
      </div>
      <div class="w-px h-8 bg-gray-600 hidden sm:block"></div>
      <div>
        <div class="text-2xl sm:text-3xl font-bold text-[#00A8D8]">&lt;5 min</div>
        <div class="text-xs sm:text-sm text-gray-400">diagnóstico</div>
      </div>
    </div>

  </div>

</section>

<!-- BENEFICIOS PREMIUM -->
<section id="beneficios"
         class="py-32 bg-[#F4F6F8] dark:bg-[#001C26] transition-colors duration-500">

  <div class="max-w-7xl mx-auto px-6">

    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- IMAGEN -->
      <div class="reveal relative">

        <div class="relative rounded-[40px] overflow-hidden shadow-2xl group">

          <img
            src="/beneficios_01.jpg"
            alt="Beneficios IteraDORA"
            class="w-full h-[520px] object-cover
                   transition-transform duration-700
                   group-hover:scale-105"
          />

          <!-- Overlay premium -->
          <div class="absolute inset-0
                      bg-gradient-to-tr
                      from-[#00334E]/40
                      via-transparent
                      to-[#00A8D8]/20">
          </div>

        </div>

      </div>


      <!-- TEXTO -->
      <div class="reveal">

      <h2 class="text-4xl md:text-5xl font-extrabold mb-8 leading-tight">
  <span class="text-black dark:text-white">
    Beneficios
  </span>
  <span class="text-[#4DBFD9]">
    IteraDORA
  </span>
</h2>

        <p class="text-lg text-gray-600 dark:text-gray-300
                  leading-relaxed mb-8">
          IteraDORA no es solo una evaluacion tecnica. Es una herramienta estrategica
          que acelera procesos, posiciona la consultoria y genera valor real en clientes
          y equipos ejecutivos.
        </p>

        <ul class="space-y-6">

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20
                        flex items-center justify-center text-[#00A8D8] font-bold">
              1
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Acelera el diagnostico en practicas DevOps con claridad inmediata.
            </p>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20
                        flex items-center justify-center text-[#00A8D8] font-bold">
              2
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Refuerza el posicionamiento como consultores integrales en nube y DevOps.
            </p>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20
                        flex items-center justify-center text-[#00A8D8] font-bold">
              3
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Genera valor tecnico y gerencial para una toma de decisiones estrategica.
            </p>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20
                        flex items-center justify-center text-[#00A8D8] font-bold">
              4
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Impulsa nuevas oportunidades comerciales en migraciones y consultoria.
            </p>
          </li>

          <li class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00A8D8]/20
                        flex items-center justify-center text-[#00A8D8] font-bold">
              5
            </div>
            <p class="text-gray-700 dark:text-gray-300">
              Permite recolectar datos clave para decisiones basadas en evidencia.
            </p>
          </li>

        </ul>

      </div>

    </div>

  </div>

</section>

  <!-- COMO FUNCIONA -->
  <section id="como-funciona"
           class="py-28 bg-[#e5e7e8] dark:bg-[#002633] transition-colors duration-500">

    <div class="max-w-6xl mx-auto px-6">

      <!-- Encabezado -->
      <div class="text-center mb-16 reveal">
        <h2 class="text-4xl md:text-5xl font-extrabold
                   text-[#00334E] dark:text-white mb-4">
          ¿Cómo funciona?
        </h2>
        <p class="text-lg text-gray-500 dark:text-gray-400 max-w-xl mx-auto">
          Tres pasos para obtener un diagnóstico claro y accionable.
        </p>
      </div>

      <!-- Cards -->
      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">

        <!-- CARD 1: Evaluación -->
        <div class="reveal group relative
                    bg-white dark:bg-[#0A3E52]
                    p-8 lg:p-10 rounded-2xl shadow-md
                    border border-gray-100 dark:border-gray-700/30
                    transition-all duration-500
                    hover:-translate-y-3 hover:shadow-xl
                    hover:border-[#00A8D8]/30">

          <!-- Número -->
          <div class="w-12 h-12 rounded-xl bg-[#00A8D8]/10
                      flex items-center justify-center
                      text-[#00A8D8] font-extrabold text-lg
                      transition-all duration-500
                      group-hover:bg-[#00A8D8] group-hover:text-white mb-5">
            1
          </div>

          <!-- Ícono -->
          <div class="mb-4">
            <svg class="w-10 h-10 text-[#00A8D8] transition-transform duration-500 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>

          <h3 class="text-xl lg:text-2xl font-bold mb-3
                     text-[#00334E] dark:text-white">
            Evaluación
          </h3>

          <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
            Responde 10 preguntas clave basadas en la metodología DORA. Sin configuraciones, sin fricción.
          </p>

          <div class="mt-5 inline-flex items-center gap-1.5
                      text-xs font-medium text-[#00A8D8]">
            <span class="w-1.5 h-1.5 rounded-full bg-[#00A8D8]"></span>
            ~3 minutos
          </div>
        </div>

        <!-- CARD 2: Análisis -->
        <div class="reveal group relative
                    bg-white dark:bg-[#0A3E52]
                    p-8 lg:p-10 rounded-2xl shadow-md
                    border border-gray-100 dark:border-gray-700/30
                    transition-all duration-500
                    hover:-translate-y-3 hover:shadow-xl
                    hover:border-[#00A8D8]/30">

          <!-- Flecha conectora (desktop) -->
          <div class="hidden md:block absolute -left-8 top-1/2 -translate-y-1/2 text-gray-300 dark:text-gray-600">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 5l7 7-7 7"/>
            </svg>
          </div>

          <!-- Número -->
          <div class="w-12 h-12 rounded-xl bg-[#00A8D8]/10
                      flex items-center justify-center
                      text-[#00A8D8] font-extrabold text-lg
                      transition-all duration-500
                      group-hover:bg-[#00A8D8] group-hover:text-white mb-5">
            2
          </div>

          <!-- Ícono -->
          <div class="mb-4">
            <svg class="w-10 h-10 text-[#00A8D8] transition-transform duration-500 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/>
              <path d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/>
            </svg>
          </div>

          <h3 class="text-xl lg:text-2xl font-bold mb-3
                     text-[#00334E] dark:text-white">
            Análisis
          </h3>

          <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
            Procesamos tus métricas con el modelo DORA y calculamos tu nivel real de madurez DevOps.
          </p>

          <div class="mt-5 inline-flex items-center gap-1.5
                      text-xs font-medium text-[#00A8D8]">
            <span class="w-1.5 h-1.5 rounded-full bg-[#00A8D8]"></span>
            Automatizado
          </div>
        </div>

        <!-- CARD 3: Recomendaciones -->
        <div class="reveal group relative
                    bg-white dark:bg-[#0A3E52]
                    p-8 lg:p-10 rounded-2xl shadow-md
                    border border-gray-100 dark:border-gray-700/30
                    transition-all duration-500
                    hover:-translate-y-3 hover:shadow-xl
                    hover:border-[#00A8D8]/30">

          <!-- Flecha conectora (desktop) -->
          <div class="hidden md:block absolute -left-8 top-1/2 -translate-y-1/2 text-gray-300 dark:text-gray-600">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 5l7 7-7 7"/>
            </svg>
          </div>

          <!-- Número -->
          <div class="w-12 h-12 rounded-xl bg-[#00A8D8]/10
                      flex items-center justify-center
                      text-[#00A8D8] font-extrabold text-lg
                      transition-all duration-500
                      group-hover:bg-[#00A8D8] group-hover:text-white mb-5">
            3
          </div>

          <!-- Ícono -->
          <div class="mb-4">
            <svg class="w-10 h-10 text-[#00A8D8] transition-transform duration-500 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>

          <h3 class="text-xl lg:text-2xl font-bold mb-3
                     text-[#00334E] dark:text-white">
            Recomendaciones
          </h3>

          <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
            Recibe un diagnóstico claro con los próximos pasos accionables para tu equipo.
          </p>

          <div class="mt-5 inline-flex items-center gap-1.5
                      text-xs font-medium text-[#00A8D8]">
            <span class="w-1.5 h-1.5 rounded-full bg-[#00A8D8]"></span>
            Resultado instantáneo
          </div>
        </div>

      </div>

    </div>

  </section>


  <!-- DIAGNOSTICO -->
  <!-- DIAGNOSTICO -->
  <section id="diagnostico"
           class="py-28 bg-[#F7FAFC] dark:bg-[#002633] transition-colors duration-500">

    <div class="max-w-6xl mx-auto px-6 text-center">

      <h2 class="text-4xl md:text-5xl font-extrabold
                 text-[#00334E] dark:text-white mb-16 reveal">
        Diagnóstico DevOps
      </h2>

      <div class="max-w-lg mx-auto">
        <div class="reveal group relative flex flex-col items-center
                    p-12 rounded-2xl shadow-md
                    transition-all duration-500
                    hover:-translate-y-4 hover:shadow-2xl
                    hover:ring-2 hover:ring-[#00A8D8]/50
                    overflow-hidden"
             style="background: linear-gradient(135deg, #ffffff 0%, #f0f9ff 40%, #e0f2fe 100%);">

          <!-- Orbe decorativo dentro de la tarjeta -->
          <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-[#00A8D8]/8 blur-2xl pointer-events-none group-hover:bg-[#00A8D8]/12 transition-colors duration-500"></div>
          <div class="absolute -bottom-8 -left-8 w-32 h-32 rounded-full bg-[#00607B]/6 blur-2xl pointer-events-none"></div>

          <!-- Versión dark -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#0A3E52] via-[#0A3550] to-[#06283a] dark:opacity-100 opacity-0 pointer-events-none"></div>
          <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-[#00A8D8]/15 blur-2xl pointer-events-none dark:opacity-100 opacity-0"></div>
          <div class="absolute -bottom-8 -left-8 w-32 h-32 rounded-full bg-[#00607B]/10 blur-2xl pointer-events-none dark:opacity-100 opacity-0"></div>

          <!-- Ícono SVG en vez de emoji -->
          <div class="relative z-10 w-20 h-20 rounded-2xl bg-gradient-to-br from-[#00A8D8]/15 to-[#00607B]/10
                      flex items-center justify-center mb-6
                      transition-transform duration-500 group-hover:scale-110 group-hover:rotate-3">
            <svg class="w-10 h-10 text-[#00A8D8]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path d="M3 3v18h18"/>
              <path d="M7 16l4-8 4 4 4-6"/>
              <circle cx="19" cy="5" r="2" fill="currentColor" stroke="none"/>
            </svg>
          </div>

          <h3 class="relative z-10 text-2xl font-bold mb-4 text-[#00334E] dark:text-white">
            Diagnóstico Integral
          </h3>

          <p class="relative z-10 text-gray-600 dark:text-gray-300 leading-relaxed mb-8 text-center">
            Evaluá la madurez DevOps de tu organización con 10 preguntas clave basadas en la metodología DORA.
            Al finalizar recibirás una clasificación: Fundacional, Intermedio o Avanzado.
          </p>

          <a href="/diagnostico"
             class="group/btn relative z-10 inline-flex items-center gap-3
                    bg-[#00A8D8] hover:bg-[#0088b0]
                    text-white px-8 py-4 rounded-2xl
                    font-bold text-base
                    shadow-lg shadow-[#00A8D8]/25
                    transition-all duration-300
                    hover:shadow-xl hover:shadow-[#00A8D8]/40
                    hover:-translate-y-1 active:scale-95
                    overflow-hidden">
            <span class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/10 to-white/0 -translate-x-full group-hover/btn:translate-x-full transition-transform duration-700"></span>
            <span class="relative z-10">Iniciar diagnóstico</span>
            <svg class="relative z-10 w-5 h-5 transition-transform duration-300 group-hover/btn:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
            </svg>
          </a>

        </div>
      </div>

    </div>

  </section>


 <footer class="bg-[#0A1929] dark:bg-[#000e17]
               border-t border-gray-800
               transition-colors duration-500">

  <div class="max-w-7xl mx-auto px-6 pt-16 pb-10">

    <!-- Grid principal -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- COL 1: Logo + descripción -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <img
            src="/logo-iteradora.png"
            alt="IteraDORA"
            class="h-9 object-contain brightness-0 invert"
          />
          <span class="text-gray-500 text-xs">by</span>
          <span class="text-white font-bold text-sm tracking-wide">ITERA PROCESS</span>
        </div>
        <p class="text-sm text-gray-400 leading-relaxed mb-5">
          Diagnóstico DevOps basado en la metodología DORA. Impulsado por Itera Process, especialistas en Cloud, Workflow Automation, AI y Data.
        </p>
        <!-- Redes sociales -->
        <div class="flex items-center gap-3">
          <a href="https://linkedin.com/company/itera-process" target="_blank" rel="noopener" title="LinkedIn" class="w-8 h-8 rounded-lg bg-white/5 hover:bg-[#00A8D8]/20 flex items-center justify-center transition-colors">
