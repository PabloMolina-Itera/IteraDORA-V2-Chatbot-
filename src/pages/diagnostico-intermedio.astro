---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Diagnóstico Intermedio - IteraDORA">
  <section class="py-12 bg-[#F7FAFC] dark:bg-[#002633] min-h-[calc(100vh-80px)]">
    <div class="max-w-4xl mx-auto px-6">
      <div class="mb-8 text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-[#00334E] dark:text-white mb-2">
          Diagnóstico Intermedio
        </h1>
        <p class="text-gray-600 dark:text-gray-300">
          Para equipos con prácticas DevOps activas que buscan optimización y mejora continua.
        </p>
      </div>

      <div class="flex justify-center">
        <iframe
          src="https://docs.google.com/forms/d/e/1FAIpQLSdtFjpCbDSH_wmVhIlQPUg41I3g2j9jUxqyRDwvF0a_nr5HGg/viewform"
          width="720"
          height="2200"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          class="border-0 rounded-xl shadow-xl bg-white w-full max-w-[720px]"
        >
          Cargando…
        </iframe>
      </div>
    </div>
  </section>
</BaseLayout>
